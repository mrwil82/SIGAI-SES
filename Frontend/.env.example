# --- URL DEL API BACKEND ---
# Si usas Docker con nginx (recomendado): /api/v1
# Si ejecutas el backend directamente:    http://localhost:8000/api/v1
# Si tienes un dominio personalizado:     https://api.tudominio.com/api/v1
#
VITE_API_BASE_URL=/api/v1
