# =============================================================================
# SIGAI-SES Backend - Variables de Entorno
# =============================================================================
# INSTRUCCIONES:
# 1. Copia este archivo como .env (copy .env.example .env)
# 2. Modifica los valores segun tu entorno (LOCAL o SUPABASE)
# 3. Ejecuta las migraciones: alembic upgrade head
# =============================================================================

# =============================================================================
# BASE DE DATOS - DESCOMENTA SOLO UNA OPCIÓN
# =============================================================================

# --- OPCIÓN 1: LOCALHOST (MySQL) ---
# Si trabajas en local con MySQL instalado
# DATABASE_URL=mysql+aiomysql://sigai:sigai_password@localhost:3306/sigai_ses

# --- OPCIÓN 2: SUPABASE (PostgreSQL) ---
# Si usas Supabase en la nube (producción/pruebas)
DATABASE_URL=postgresql+asyncpg://postgres:TU_CONTRASEÑA@db.TU_PROYECTO.supabase.co:5432/postgres

# --- SYNC (para scripts y migraciones) ---
# LOCAL: DATABASE_URL_SYNC=mysql://sigai:sigai_password@localhost:3306/sigai_ses
DATABASE_URL_SYNC=postgresql://postgres:TU_CONTRASEÑA@db.TU_PROYECTO.supabase.co:5432/postgres

# =============================================================================
# CLAVE SECRETA JWT
# =============================================================================
# IMPORTANTE: Genera una clave única para producción
# PowerShell: -join ((1..32) | ForEach-Object { '{0:x2}' -f (Get-Random -Max 256) })
SECRET_KEY=cambiar-esta-clave-secreta-en-produccion-2024

# =============================================================================
# JWT CONFIGURACIÓN (no cambiar)
# =============================================================================
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# =============================================================================
# CORS - ORIGENES PERMITIDOS
# =============================================================================
# LOCAL: http://localhost,http://localhost:5173
# PRODUCCIÓN: https://sigai.tudominio.com
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173

# =============================================================================
# USUARIO ADMINISTRADOR INICIAL
# =============================================================================
# Se crea automáticamente en la primera ejecución
ADMIN_EMAIL=admin@securitas.com
ADMIN_PASSWORD=Admin123!
ADMIN_NAME=Administrador SIGAI
ADMIN_CEDULA=0000000000
ADMIN_CODIGO=ADM001

# =============================================================================
# PUERTO (opcional)
# =============================================================================
# PORT=8000
