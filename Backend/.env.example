# =============================================================================
# SIGAI-SES Backend - Variables de Entorno
# =============================================================================
# INSTRUCCIONES:
# 1. Copia este archivo como .env (copy .env.example .env)
# 2. Descomenta solo UNA opción de base de datos
# 3. Ejecuta: cd Backend && uvicorn app.main:app --reload
# =============================================================================

# --- BASE DE DATOS ---
# === OPCIÓN 1: LOCAL (MySQL) - Descomenta estas 2 líneas ===
#DATABASE_URL=mysql+aiomysql://root:@localhost:3306/sigai_ses
#DATABASE_URL_SYNC=mysql+pymysql://root:@localhost:3306/sigai_ses

# === OPCIÓN 2: SUPABASE (PostgreSQL) - Descomenta estas 2 líneas ===
#DATABASE_URL=postgresql+asyncpg://postgres:TU_PASSWORD@db.TU_PROYECTO.supabase.co:5432/postgres
#DATABASE_URL_SYNC=postgresql+psycopg2://postgres:TU_PASSWORD@db.TU_PROYECTO.supabase.co:5432/postgres

# --- CLAVE SECRETA JWT ---
SECRET_KEY=clave_secreta_super_segura_123

# --- ALGORITMO JWT ---
ALGORITHM=HS256

# --- EXPIRACION DEL TOKEN (minutos) ---
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- CORS - ORIGENES PERMITIDOS ---
# LOCAL: http://localhost,http://localhost:5173
# PRODUCCIÓN: https://tudominio.com,https://*.onrender.com
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:8000,http://localhost:5173,http://127.0.0.1,http://127.0.0.1:8000,http://127.0.0.1:5173

# --- USUARIO ADMINISTRADOR INICIAL ---
ADMIN_EMAIL=admin@securitas.com
ADMIN_PASSWORD=Admin123!
ADMIN_NAME=Administrador SIGAI
ADMIN_CEDULA=0000000000
ADMIN_CODIGO=ADM001
