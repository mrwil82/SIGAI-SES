# =============================================================================
# SIGAI-SES Backend - Variables de Entorno
# =============================================================================
# Copia este archivo como .env y modifica los valores segun tu servidor.
# Ejemplo: cp .env.example .env
# =============================================================================

# --- BASE DE DATOS ---
# Formato: mysql+aiomysql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_BD
#
# Ejemplos segun proveedor:
#   MySQL local:     mysql+aiomysql://sigai:mipassword@localhost:3306/sigai_ses
#   AWS RDS:         mysql+aiomysql://admin:mipassword@mi-db.xxxxx.us-east-1.rds.amazonaws.com:3306/sigai_ses
#   Azure DB:        mysql+aiomysql://admin@mibase.mysql.database.azure.com:3306/sigai_ses
#   Google Cloud:    mysql+aiomysql://root:mipassword@IP_PRIVADA:3306/sigai_ses
#   DigitalOcean:    mysql+aiomysql://doadmin:mipassword@db-mibase-do-user-XXXX.db.ondigitalocean.com:3306/sigai_ses
#
DATABASE_URL=mysql+aiomysql://sigai:sigai_password@localhost:3306/sigai_ses

# --- CLAVE SECRETA JWT ---
# IMPORTANTE: Cambia esta valeur en produccion. Genera una clave aleatoria.
# Linux/Mac:  openssl rand -hex 32
# PowerShell: -join ((1..32) | ForEach-Object { '{0:x2}' -f (Get-Random -Max 256) })
#
SECRET_KEY=cambiar-esta-clave-secreta-en-produccion-2024

# --- ALGORITMO JWT ---
# No cambiar a menos que sepas lo que haces
ALGORITHM=HS256

# --- EXPIRACION DEL TOKEN (minutos) ---
# Default: 480 minutos (8 horas)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- CORS - ORIGENES PERMITIDOS ---
# Lista separada por comas de los dominios que pueden acceder al API.
# Ejemplos:
#   Desarrollo:  http://localhost:5173,http://localhost
#   Produccion:  https://sigai.tudominio.com,https://www.tudominio.com
#
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80

# --- USUARIO ADMINISTRADOR INICIAL ---
# Se crea automaticamente en la primera ejecucion.
# Puedes cambiar estos valores antes de iniciar por primera vez.
#
ADMIN_EMAIL=admin@securitas.com
ADMIN_PASSWORD=Admin123!
ADMIN_NAME=Administrador SIGAI
ADMIN_CEDULA=0000000000
ADMIN_CODIGO=ADM001

# --- PUERTO DEL SERVIDOR ---
# Solo necesario si ejecutas sin Docker
# PORT=8000
