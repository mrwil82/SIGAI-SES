# Configuración para Supabase (PostgreSQL gratuito)
# 1. Ve a https://supabase.com y crea una cuenta
# 2. Crea un nuevo proyecto
# 3. Ve a Project Settings > Database > Connection string
# 4. Copia la URI de conexión (postgresql://postgres:xxxx@db.xxxx.supabase.co:5432/postgres)
# 5. Pégala aquí:

DATABASE_URL=postgresql+asyncpg://postgres:TU_CONTRASEÑA@db.TU_PROYECTO.supabase.co:5432/postgres
DATABASE_URL_SYNC=postgresql://postgres:TU_CONTRASEÑA@db.TU_PROYECTO.supabase.co:5432/postgres

# 6. Reemplaza TU_CONTRASEÑA y TU_PROYECTO con los valores reales
# 7. Renombra este archivo a .env
# 8. Ejecuta las migraciones:
#    cd Backend
#    .venv\Scripts\alembic upgrade head
