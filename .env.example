# =============================================================================
# SIGAI-SES - Variables de Entorno
# =============================================================================
# INSTRUCCIONES:
# - Docker Compose: copia como .env en la raiz y ejecuta docker-compose up -d
# - Render: configura estas variables en el dashboard de Render
# - Supabase: usa la DATABASE_URL que entrega Supabase (Session Pooler)
# =============================================================================

# ──────────── DOCKER COMPOSE ────────────
# Estas variables se usan para crear la BD MariaDB y conectar el backend.
# Solo aplican si usas docker-compose.yml (NO Render).
#
DB_ROOT_PASSWORD=cambiar-esta-password-root
DB_NAME=sigai_ses
DB_USER=sigai
DB_PASSWORD=cambiar-esta-password

# ──────────── SUPABASE (PostgreSQL) ────────────
# La URL asincrona para SQLAlchemy + asyncpg.
# La URL sincrona para migraciones (Alembic/psycopg2).
# Obtienes estas URLs de Supabase > Project Settings > Database > Connection string
# Usa "Session Pooler" (puerto 5432) para mejor rendimiento.
#
# Formato:
#   DATABASE_URL=postgresql+asyncpg://postgres.XXXXXXXX:password@aws-0-us-west-2.pooler.supabase.com:5432/postgres
#   DATABASE_URL_SYNC=postgresql+psycopg2://postgres.XXXXXXXX:password@aws-0-us-west-2.pooler.supabase.com:5432/postgres
#
# NOTA: La variable DATABASE_URL_SYNC solo se usa para migraciones locales,
# Render solo necesita DATABASE_URL (asincrona).
#
#DATABASE_URL=postgresql+asyncpg://...
#DATABASE_URL_SYNC=postgresql+psycopg2://...

# ──────────── CLAVE SECRETA JWT ────────────
# Genera una clave unica con: openssl rand -hex 32
# En Render, configurala como variable secreta (sync: false).
#
SECRET_KEY=cambiar-esta-clave-secreta-en-produccion

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ──────────── CORS ────────────
# Dominios que pueden acceder al API (separados por comas).
# Incluye el dominio del frontend y el de Render.
#
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173,https://sigai-ses-api.onrender.com,https://sigai-ses.onrender.com

# ──────────── USUARIO ADMIN ────────────
# Se crea automaticamente en la primera ejecucion si no existe.
#
ADMIN_EMAIL=admin@securitas.com
ADMIN_PASSWORD=Admin123!
ADMIN_NAME=Administrador SIGAI
ADMIN_CEDULA=0000000000
ADMIN_CODIGO=ADM001
