# =============================================================================
# SIGAI-SES - Docker Compose (Produccion)
# =============================================================================
# INSTRUCCIONES:
# 1. Copia este archivo como .env en la raiz del proyecto
# 2. Modifica los valores segun tu servidor
# 3. Ejecuta: docker-compose up -d
# =============================================================================

# --- BASE DE DATOS ---
# Estas variables se usan para crear la BD y conectar el backend.
# Cambia todos los valores para produccion.
#
DB_ROOT_PASSWORD=cambiar-esta-password-root
DB_NAME=sigai_ses
DB_USER=sigai
DB_PASSWORD=cambiar-esta-password

# --- CLAVE SECRETA JWT ---
# Genera una clave unica con: openssl rand -hex 32
#
SECRET_KEY=cambiar-esta-clave-secreta-en-produccion

# --- CORS - ORIGENES PERMITIDOS ---
# Dominios que pueden acceder al API (separados por comas).
# Ejemplo: https://sigai.tudominio.com,https://www.tudominio.com
#
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80

# --- USUARIO ADMINISTRADOR ---
# Se crea automaticamente en la primera ejecucion.
#
ADMIN_EMAIL=admin@securitas.com
ADMIN_PASSWORD=Admin123!
ADMIN_NAME=Administrador SIGAI
